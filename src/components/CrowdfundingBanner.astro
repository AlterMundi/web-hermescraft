---
const { href = '#crowdfunding' } = Astro.props;
---
<a
  href={href}
  class="sticky-banner fixed top-0 left-0 right-0 z-50 flex items-center justify-center gap-3 px-4 py-2 bg-hermes text-ink font-display text-[10px] md:text-xs uppercase tracking-widest hover:bg-hermes-light transition-colors"
  style="box-shadow: inset 0 -3px 0 0 #E64A19, 0 4px 20px -4px rgba(0,0,0,0.2);"
>
  <span class="inline-block w-2.5 h-2.5 bg-ink animate-pulse"></span>
  <span>
    <span class="hidden md:inline">Estamos en seed round ·</span>
    Sumate a la primera camada
  </span>
  <span aria-hidden="true">→</span>
</a>
