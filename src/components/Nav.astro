---
const base = import.meta.env.BASE_URL;
const links = [
  { href: `${base}#companeros`,    label: 'Entidades' },
  { href: `${base}#rol-master`,    label: 'Rol Master' },
  { href: `${base}#como-funciona`, label: 'Cómo funciona' },
  { href: `${base}equipo`,         label: 'Equipo' },
  { href: `${base}blog`,           label: 'Blog' },
  { href: `${base}pitch-deck`,     label: 'Pitch Deck' },
];
---
<nav class="relative z-30 container-narrow flex items-center justify-between py-5">
  <a href="#top" class="flex items-center gap-3 group">
    <!-- Logo bloque daemon con D naranja -->
    <div class="relative w-11 h-11 grass-block" style="box-shadow: inset 0 -8px 0 0 #8B5A3C, inset 0 -16px 0 0 #8B5A3C, inset 0 4px 0 0 #94C95C;">
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="font-display text-lg text-daemon text-mc">D</span>
      </div>
    </div>
    <span class="font-display text-xs tracking-widest text-cream text-mc">
      DAEMON<span class="text-daemon">CRAFT</span>
    </span>
  </a>

  <div class="hidden md:flex items-center gap-7">
    {links.map((l) => (
      <a href={l.href} class="font-mono text-xs uppercase tracking-widest text-cream hover:text-daemon text-mc transition-colors">
        {l.label}
      </a>
    ))}
  </div>

  <a href={`${base}pitch-deck#crowdfunding`} class="btn-mc btn-mc-gold !py-2 !px-4 !text-[10px]">
    Invocar
  </a>
</nav>
