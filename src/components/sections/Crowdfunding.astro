---
const { href = '#crowdfunding' } = Astro.props;
---
<section id="crowdfunding" class="relative py-24 md:py-32 bg-dirt overflow-hidden">
  <!-- borde pasto arriba -->
  <div class="absolute top-0 inset-x-0 h-6 bg-grass" style="box-shadow: inset 0 -3px 0 0 #5A7F3A, inset 0 3px 0 0 #94C95C;"></div>
  <!-- textura tierra -->
  <div class="absolute inset-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(circle at 20% 30%, #6B4423 2px, transparent 3px), radial-gradient(circle at 70% 60%, #6B4423 2px, transparent 3px), radial-gradient(circle at 40% 80%, #6B4423 2px, transparent 3px); background-size: 80px 80px;"></div>

  <div class="relative container-narrow">
    <div class="max-w-4xl mx-auto text-center mb-12">
      <div class="inline-block mb-5">
        <div class="entity-tag text-lg">DAEMONCRAFT · SEED ROUND</div>
      </div>
      <h2 class="h-display text-mc text-cream mb-6">
        Estamos armando <span class="text-hermes">la primera camada</span> de familias.
      </h2>
      <p class="font-sans text-cream text-mc text-lg md:text-xl max-w-3xl mx-auto leading-relaxed">
        18 meses de runway. 12.000 usuarios. 500+ agentes en vivo.
        Un proyecto soberano de AlterMundi — sin capital de riesgo tradicional.
        Vos podés estar desde el día uno.
      </p>
    </div>

    <!-- Metrics del deck -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-14">
      {[
        { metric: '$450K', label: 'Seed objetivo' },
        { metric: '10,000+', label: 'Usuarios M12' },
        { metric: '$12K+', label: 'MRR M9' },
        { metric: '500+', label: 'Agentes M6' },
      ].map((m) => (
        <div class="bg-cream border-4 border-ink p-4 text-center" style="box-shadow: inset 0 -3px 0 0 rgba(0,0,0,0.2), inset 0 3px 0 0 rgba(255,255,255,0.5), 4px 4px 0 0 rgba(0,0,0,0.3);">
          <div class="font-display text-2xl md:text-3xl text-hermes-dark mb-1">{m.metric}</div>
          <div class="font-mono text-[10px] uppercase tracking-widest text-ink/60">{m.label}</div>
        </div>
      ))}
    </div>

    <!-- Big CTA block -->
    <div class="max-w-3xl mx-auto bg-hermes border-4 border-hermes-dark p-8 md:p-10 text-center" style="box-shadow: inset 0 -4px 0 0 rgba(0,0,0,0.2), inset 0 4px 0 0 rgba(255,255,255,0.4), 8px 8px 0 0 rgba(0,0,0,0.4);">
      <div class="font-display text-[10px] text-ink mb-3 tracking-widest">PRÓXIMO PASO</div>
      <h3 class="font-serif font-bold text-2xl md:text-3xl text-ink mb-4 leading-snug">
        45 minutos. Demo en vivo con agentes reales, Telegram bridge y portal entre mundos.
      </h3>
      <p class="text-ink/80 mb-6">
        Si sos inversor, escuela o familia founder — agendamos la demo esta semana.
      </p>
      <a href="mailto:nicoechaniz@daemoncraft.ai?subject=Demo%20DaemonCraft%20Seed"
         class="btn-mc btn-mc-wood !text-sm !px-8 !py-4">
        Agendar demo de 45 min →
      </a>
      <div class="mt-5 font-mono text-xs text-ink/60">
        Nicolás Echániz · nicoechaniz@daemoncraft.ai · @nicoechaniz
      </div>
    </div>

    <p class="text-center mt-10 font-mono text-[10px] uppercase tracking-widest text-cream/70">
      The architecture is proven · The timing is perfect · The team is ready
    </p>
  </div>
</section>
