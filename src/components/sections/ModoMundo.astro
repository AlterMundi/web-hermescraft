---
const entradas = [
  {
    modo: 'Tu idea',
    prompt: '"Quiero una isla flotante con dragones."',
    arma: 'Aether + Dragon Mounts · 5 islas conectadas · nidos con huevos.',
    color: 'border-hermes',
  },
  {
    modo: 'Aventura',
    prompt: '"La historia que pediste en Rol Master."',
    arma: 'Estructuras custom + mobs de la narrativa · pistas colocadas en el orden del arco.',
    color: 'border-cyan',
  },
  {
    modo: 'Temática',
    prompt: '"Reino medieval con magia."',
    arma: 'Ars Nouveau + Valhelsia · aldea feudal · NPCs con quests.',
    color: 'border-grass',
  },
];

const stack = [
  'Forge', 'Fabric', 'Datapacks', 'Structure API', 'Worldgen custom', 'Whitelist curada por AlterMundi',
];
---

<section id="modo-mundo" class="relative py-20 md:py-28 bg-night-deep overflow-hidden">
  <!-- grid sutil de fondo -->
  <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: linear-gradient(rgba(0,229,255,0.25) 1px, transparent 1px), linear-gradient(90deg, rgba(0,229,255,0.25) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative container-narrow">
    <div class="text-center max-w-3xl mx-auto mb-14">
      <span class="h-mini text-cyan text-mc">03 / MODO</span>
      <h2 class="h-display text-mc text-cream mt-3 mb-5">
        Generador de <span class="text-cyan">Mundos</span>
      </h2>
      <p class="font-sans text-cream/90 text-lg max-w-2xl mx-auto leading-relaxed">
        El Daemon conoce mods y tiene una biblioteca de estructuras.
        Le pasás una idea o elegís una aventura; arma el escenario:
        terreno, mobs, lore, mecánicas.
      </p>
    </div>

    <!-- 3 entradas posibles -->
    <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto mb-12">
      {entradas.map((e) => (
        <article class={`bg-cream/5 border-l-4 ${e.color} border-y-2 border-r-2 border-y-cream/10 border-r-cream/10 p-5`}>
          <div class="font-mono text-[10px] uppercase tracking-widest text-cyan mb-3">{e.modo}</div>
          <div class="font-serif text-cream text-lg italic mb-4 leading-snug">{e.prompt}</div>
          <div class="pt-3 border-t border-cream/10">
            <div class="font-mono text-[10px] uppercase tracking-widest text-hermes mb-1">Arma</div>
            <div class="font-sans text-sm text-cream/80 leading-relaxed">{e.arma}</div>
          </div>
        </article>
      ))}
    </div>

    <!-- Stack tech -->
    <div class="max-w-4xl mx-auto text-center">
      <div class="font-mono text-[10px] uppercase tracking-widest text-cream/50 mb-4">Stack del generador</div>
      <div class="flex flex-wrap gap-2 justify-center">
        {stack.map((s) => (
          <span class="font-mono text-[11px] px-3 py-1.5 bg-cream/5 text-cream/80 border border-cyan/30">
            {s}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
