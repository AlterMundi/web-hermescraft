---
const ejemplos = [
  {
    tipo: 'Descomponer',
    pide: 'Construí una casa de 3 pisos con techo rojo y 2 ventanas por piso.',
    hace: 'Piso 1 · 3×4 roble. Piso 2 · idéntico arriba. Piso 3 · igual. Techo · lana roja en pendiente. Ventanas · vidrio en norte y sur.',
    enseña: 'Romper un objetivo en pasos chicos.',
  },
  {
    tipo: 'Condicionales',
    pide: 'Si un creeper se acerca a 5 bloques, alejate. Si es de día, volvé.',
    hace: 'Monitorea entidades cercanas. Retrocede en diagonal al detectar creeper. Reanuda tarea al amanecer.',
    enseña: 'Pensar en SI / ENTONCES.',
  },
  {
    tipo: 'Cuantificar',
    pide: 'Recorré el bosque y traé 10 troncos de roble y 5 de abedul.',
    hace: 'Recorrido en espiral. Cuenta en vivo: roble 6/10, abedul 3/5. Vuelve cuando completa.',
    enseña: 'Cantidades, tipos, seguimiento de estado.',
  },
];
---

<section id="modo-prompt" class="relative py-20 md:py-28 bg-night overflow-hidden">
  <!-- Grid de código de fondo -->
  <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: linear-gradient(rgba(245,197,66,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(245,197,66,0.3) 1px, transparent 1px); background-size: 24px 24px;"></div>

  <div class="relative container-narrow">
    <div class="text-center max-w-3xl mx-auto mb-14">
      <span class="h-mini text-hermes text-mc">04 / MODO</span>
      <h2 class="h-display text-mc text-cream mt-3 mb-5">
        Prompt & <span class="text-hermes">Lógica</span>
      </h2>
      <p class="font-sans text-cream/90 text-lg max-w-2xl mx-auto leading-relaxed">
        Jugar es instruir. El Daemon hace lo que le decís — cuando aprendés a
        decirlo con claridad, el mundo te obedece. Es programación
        sin parecerse a programar.
      </p>
    </div>

    <!-- Ejemplos compactos en grid -->
    <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto">
      {ejemplos.map((e) => (
        <article class="bg-cream/5 border-2 border-cream/10 p-5">
          <div class="inline-block bg-hermes text-ink font-display text-[10px] uppercase tracking-widest px-2 py-1 border-2 border-hermes-dark mb-4">
            {e.tipo}
          </div>
          <div class="font-serif text-cream leading-snug mb-3">"{e.pide}"</div>
          <div class="font-mono text-[10px] uppercase tracking-widest text-hermes pt-3 border-t border-cream/10">
            Enseña · <span class="text-cream/80 normal-case tracking-normal">{e.enseña}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
