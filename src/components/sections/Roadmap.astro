---
const fases = [
  {
    n: '01',
    time: '0–1 mes',
    niño: 'Un compañero que mina, construye y charla de igual a igual.',
    familia: 'Configuración de perfil por Telegram. Primeras preguntas de Daemon.',
  },
  {
    n: '02',
    time: '1–3 meses',
    niño: 'Aventuras de rol generadas por IA basadas en sus libros o ideas.',
    familia: 'Reportes semanales con logros y observaciones emocionales.',
  },
  {
    n: '03',
    time: '3–6 meses',
    niño: 'Desafíos lógicos y de prompting escalados a su nivel escolar.',
    familia: 'Dashboard de habilidades desarrolladas. Sugerencias para reforzar en casa.',
  },
  {
    n: '04',
    time: '6+ meses',
    niño: 'Servidores compartidos entre amigos. Daemon como moderador social.',
    familia: 'Comunidad de familias. Mercado de aventuras y perfiles.',
  },
];
---
<section id="roadmap" class="relative py-24 md:py-36">
  <div class="container-narrow">
    <div class="max-w-3xl mb-16">
      <span class="h-mini">05 / Roadmap</span>
      <div class="w-12 h-0.5 bg-hermes mt-3 mb-6"></div>
      <h2 class="h-display">De compañero a ecosistema</h2>
    </div>

    <div class="relative">
      <!-- línea vertical central -->
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-0.5 bg-hermes/20 -translate-x-1/2"></div>

      <div class="space-y-12 md:space-y-20">
        {fases.map((f, i) => (
          <div class={`relative grid md:grid-cols-2 gap-6 md:gap-16 ${i % 2 === 0 ? '' : 'md:[&>*:first-child]:order-2'}`}>
            <!-- bloque fase -->
            <div class={i % 2 === 0 ? 'md:text-right' : ''}>
              <div class={`inline-flex items-center gap-3 ${i % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
                <span class="block-icon !w-4 !h-4"></span>
                <span class="font-display text-hermes text-xs">FASE {f.n}</span>
              </div>
              <div class="font-mono text-[11px] uppercase tracking-widest text-teal-digital mt-2 mb-4">{f.time}</div>
              <div class={`space-y-3 ${i % 2 === 0 ? 'md:ml-auto md:max-w-sm' : 'md:max-w-sm'}`}>
                <div>
                  <div class="font-mono text-[10px] uppercase tracking-wider text-cream/50 mb-1">El niño vive</div>
                  <p class="text-cream/90">{f.niño}</p>
                </div>
                <div>
                  <div class="font-mono text-[10px] uppercase tracking-wider text-cream/50 mb-1">La familia recibe</div>
                  <p class="text-cream/70 text-sm">{f.familia}</p>
                </div>
              </div>
            </div>
            <!-- punto central -->
            <div class="hidden md:flex items-start justify-center relative">
              <div class="w-6 h-6 bg-void border-2 border-hermes z-10 mt-1"
                   style="box-shadow: inset 0 0 0 2px rgba(255,87,34,0.3);"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
