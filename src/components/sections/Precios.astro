---
const tiers = [
  {
    name: 'Free',
    price: '$0',
    period: '/mes',
    tagline: 'Probalo sin pagar',
    desc: 'Un Daemon con uno de los 4 presets, hasta 100 acciones por día.',
    features: [
      '1 perfil de Daemon',
      '100 acciones/día',
      '4 SOULs preset (Leñador, Arquitecta, Tutora, Guerrero)',
      'Chat in-game',
    ],
    cta: 'Arrancar gratis',
    color: 'bg-stone border-stone-dark',
    textColor: 'text-ink',
    priceColor: 'text-ink',
  },
  {
    name: 'Companion',
    price: '$5',
    period: '/mes',
    tagline: 'El plan familia',
    desc: 'Hasta 3 perfiles (uno por hijo), acciones ilimitadas y puente con Telegram.',
    features: [
      'Hasta 3 perfiles',
      'Acciones ilimitadas',
      'Reportes por Telegram',
      'Guardian Mode básico',
      'Memoria persistente',
    ],
    cta: 'Elegir Companion',
    highlight: true,
    color: 'bg-hermes border-hermes-dark',
    textColor: 'text-ink',
    priceColor: 'text-ink',
  },
  {
    name: 'Creator',
    price: '$15',
    period: '/mes',
    tagline: 'Hacelo tuyo',
    desc: 'Perfiles ilimitados + fine-tuning del SOUL + venta en el marketplace.',
    features: [
      'Perfiles ilimitados',
      'Fine-tune tu propio SOUL',
      'Publicar en marketplace',
      'Revenue share 82/18',
      'API y webhooks',
    ],
    cta: 'Elegir Creator',
    color: 'bg-[#8A4FC9] border-[#5E3089]',
    textColor: 'text-cream',
    priceColor: 'text-cream',
  },
  {
    name: 'School',
    price: '$99',
    period: '/mes',
    tagline: 'Aulas y clubes',
    desc: 'Realm privado con 20 perfiles + Guardian Mode completo + panel docente.',
    features: [
      'Realm privado dedicado',
      '20 perfiles incluidos',
      'Guardian Mode completo',
      'Dashboard pedagógico',
      'Onboarding 1-a-1',
    ],
    cta: 'Hablar con ventas',
    color: 'bg-ink border-night-deep',
    textColor: 'text-cream',
    priceColor: 'text-hermes',
  },
];
---
<section id="precios" class="relative py-16 md:py-20 bg-ink">
  <div class="container-narrow relative">
    <div class="text-center max-w-3xl mx-auto mb-14">
      <span class="h-mini text-cream">04 / Precios</span>
      <h2 class="h-display text-cream mt-3 mb-5">
        Elegí tu tier.
      </h2>
      <p class="font-sans text-cream/80 text-lg max-w-2xl mx-auto">
        Empezá gratis. Subí de tier cuando tu familia o tu escuela lo necesite.
        Sin contratos largos. Cancelás cuando quieras.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {tiers.map((t) => (
        <article class={`relative border-4 ${t.color} ${t.textColor} p-6 flex flex-col ${t.highlight ? 'lg:-translate-y-3 lg:scale-[1.03]' : ''}`}
                 style="box-shadow: inset 0 -4px 0 0 rgba(0,0,0,0.2), inset 0 4px 0 0 rgba(255,255,255,0.3), 6px 6px 0 0 rgba(0,0,0,0.25);">
          {t.highlight && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-ink text-hermes font-display text-[10px] px-3 py-1.5 tracking-widest shadow-pixel">
              MÁS ELEGIDO
            </div>
          )}

          <div class="font-display text-xs uppercase tracking-widest mb-2 opacity-80">{t.name}</div>
          <div class="flex items-baseline gap-1 mb-1">
            <span class={`font-display text-4xl ${t.priceColor}`}>{t.price}</span>
            <span class={`font-mono text-sm ${t.priceColor} opacity-70`}>{t.period}</span>
          </div>
          <div class="font-serif italic text-sm mb-4 opacity-80">{t.tagline}</div>

          <p class="text-sm mb-4 opacity-90 leading-snug">{t.desc}</p>

          <ul class="space-y-2 text-sm mb-6 flex-1">
            {t.features.map((f) => (
              <li class="flex items-start gap-2">
                <span class="flex-shrink-0 w-3 h-3 bg-current opacity-70 mt-1"></span>
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <a href="#crowdfunding"
             class={`btn-mc ${t.highlight ? 'btn-mc-gold' : t.textColor === 'text-cream' ? 'btn-mc-wood' : 'bg-cream !text-ink border-ink'} justify-center text-center`}>
            {t.cta}
          </a>
        </article>
      ))}
    </div>

    <div class="text-center mt-10">
      <p class="font-mono text-xs uppercase tracking-widest text-cream/60">
        COPPA audit incluida · Datos en tu región · Cancelación 1 click
      </p>
    </div>
  </div>
</section>
