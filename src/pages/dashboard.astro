---
import Layout from '../layouts/Layout.astro';

const agents = [
  {
    name: 'Producto',
    status: 'active',
    icon: '🛠️',
    doing: 'Definiendo MVP v0.1, SOULs, gameplay loop',
    next: 'Especificaciones técnicas del agente en Minecraft',
    done: ['Concepto central', '4 SOULs', 'Modelo de precios', 'Specs MVP v0.1'],
    health: 85,
  },
  {
    name: 'Marca',
    status: 'active',
    icon: '🎨',
    doing: 'Landing page, skins, paleta, copy',
    next: 'Video demo 60s, kit de prensa',
    done: ['Rebrand DaemonCraft', 'Landing Astro', 'Skins 4 SOULs', 'Paleta + tipografía'],
    health: 90,
  },
  {
    name: 'Growth',
    status: 'active',
    icon: '📈',
    doing: 'Contenido blog, outreach influencers, email funnel',
    next: 'Publicar primer post en blog, 10 DMs a influencers',
    done: ['Investigación 200+ influencers', '30 posts calendario', '5 emails funnel', 'Deck seed'],
    health: 75,
  },
  {
    name: 'Tech',
    status: 'blocked',
    icon: '⚙️',
    doing: 'Esperando decisión de stack (backend, LLM, cloud)',
    next: 'Arquitectura backend, prototipo conexión Minecraft',
    done: ['Specs MVP v0.1', 'Bridge protocols research'],
    health: 40,
  },
  {
    name: 'Comunidad',
    status: 'active',
    icon: '💬',
    doing: 'Setup Discord, guía de bienvenida, roles',
    next: 'Crear server Discord, invitar primeros 10 miembros',
    done: ['Estructura canales', 'Roles definidos', 'Reglas', 'Bot specs'],
    health: 70,
  },
];

const botHermes = {
  name: 'Hermes',
  type: 'Bot Minecraft',
  status: 'dev',
  doing: 'Agente autónomo que vive en servidores Minecraft. Se conecta, percibe, razona y actúa.',
  skills: ['chat', 'build', 'mine', 'combat', 'follow', 'remember'],
  soul: 'Leñador (default)',
};

const systemDaemon = {
  name: 'Daemon',
  type: 'Sistema / Plataforma',
  status: 'live',
  doing: 'Cloud-native platform. Orquesta agentes, gestiona memoria, conecta con Telegram, sirve la web.',
  components: ['Web (Astro)', 'API Gateway', 'Agent Core', 'Memory Store', 'Telegram Bridge'],
};

const metrics = [
  { label: 'Waitlist', value: 0, target: 100, phase: 'Fase 0' },
  { label: 'Discord', value: 0, target: 100, phase: 'Fase 0' },
  { label: 'Skins', value: 5, target: 5, phase: 'Done' },
  { label: 'Posts blog', value: 0, target: 5, phase: 'S1' },
  { label: 'MVP progress', value: 20, target: 100, phase: 'S1-S4' },
];

function statusColor(s) {
  return s === 'active' ? 'bg-emerald-500' : s === 'blocked' ? 'bg-red-500' : 'bg-amber-500';
}
function statusText(s) {
  return s === 'active' ? 'Activo' : s === 'blocked' ? 'Bloqueado' : 'En progreso';
}
---

<Layout title="DaemonCraft Dashboard">
  <div class="min-h-screen bg-void text-cream font-sans">
    <!-- Header -->
    <header class="border-b border-void-light bg-void-light/50 backdrop-blur sticky top-0 z-50">
      <div class="container-narrow flex items-center justify-between py-4">
        <div class="flex items-center gap-3">
          <span class="text-2xl">👻</span>
          <div>
            <h1 class="font-display text-sm tracking-wider text-daemon">DAEMONCRAFT</h1>
            <p class="font-mono text-[10px] text-cream/50">Dashboard de Agentes · Fase 0 · Semana 1</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <span class="font-mono text-xs text-emerald-400">Sistema online</span>
        </div>
      </div>
    </header>

    <main class="container-narrow py-8 space-y-8">
      <!-- System & Bot Overview -->
      <section class="grid md:grid-cols-2 gap-4">
        <div class="mc-card bg-void-light border-daemon/30">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">🚀</span>
            <h2 class="font-display text-xs text-daemon tracking-wider">DAEMON · Sistema</h2>
          </div>
          <p class="text-sm text-cream/80 mb-3">{systemDaemon.doing}</p>
          <div class="flex flex-wrap gap-1">
            {systemDaemon.components.map(c => (
              <span class="font-mono text-[9px] px-2 py-1 bg-daemon/10 text-daemon border border-daemon/20">{c}</span>
            ))}
          </div>
        </div>
        <div class="mc-card bg-void-light border-cyan/30">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">🤖</span>
            <h2 class="font-display text-xs text-cyan tracking-wider">HERMES · Bot</h2>
          </div>
          <p class="text-sm text-cream/80 mb-3">{botHermes.doing}</p>
          <div class="flex flex-wrap gap-1">
            {botHermes.skills.map(s => (
              <span class="font-mono text-[9px] px-2 py-1 bg-cyan/10 text-cyan border border-cyan/20">{s}</span>
            ))}
          </div>
        </div>
      </section>

      <!-- Agents Grid -->
      <section>
        <h2 class="font-display text-sm tracking-wider text-cream mb-4">👥 Agentes Activos</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {agents.map(a => (
            <div class={`mc-card relative overflow-hidden ${a.status === 'blocked' ? 'border-red-500/30' : ''}`}>
              <div class={`absolute top-0 left-0 w-full h-1 ${statusColor(a.status)}`}></div>
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                  <span class="text-xl">{a.icon}</span>
                  <div>
                    <h3 class="font-serif font-bold text-cream">{a.name}</h3>
                    <span class={`font-mono text-[9px] uppercase ${a.status === 'blocked' ? 'text-red-400' : 'text-emerald-400'}`}>
                      {statusText(a.status)}
                    </span>
                  </div>
                </div>
                <div class="font-display text-lg text-cream/20">{a.health}%</div>
              </div>

              <div class="space-y-2 text-sm">
                <div>
                  <span class="font-mono text-[9px] text-cream/40 uppercase">Haciendo</span>
                  <p class="text-cream/80">{a.doing}</p>
                </div>
                <div>
                  <span class="font-mono text-[9px] text-cream/40 uppercase">Próximo</span>
                  <p class="text-cream/60">{a.next}</p>
                </div>
              </div>

              <div class="mt-3 pt-3 border-t border-cream/10">
                <span class="font-mono text-[9px] text-cream/40 uppercase">Hecho ({a.done.length})</span>
                <div class="flex flex-wrap gap-1 mt-1">
                  {a.done.map(d => (
                    <span class="font-mono text-[8px] px-1.5 py-0.5 bg-cream/5 text-cream/60">{d}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Metrics -->
      <section>
        <h2 class="font-display text-sm tracking-wider text-cream mb-4">📊 Métricas Fase 0</h2>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
          {metrics.map(m => (
            <div class="mc-card text-center py-4">
              <div class="font-display text-2xl text-daemon">{m.value}</div>
              <div class="font-mono text-[9px] text-cream/40 uppercase mt-1">{m.label}</div>
              <div class="font-mono text-[9px] text-cream/30 mt-0.5">meta: {m.target}</div>
              <div class="w-full bg-void h-1 mt-2 rounded-full overflow-hidden">
                <div class="bg-daemon h-full rounded-full transition-all" style={`width: ${Math.min(100, (m.value / m.target) * 100)}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Quick Actions -->
      <section class="mc-card bg-daemon/5 border-daemon/20">
        <h2 class="font-display text-xs tracking-wider text-daemon mb-3">⚡ Acciones Rápidas</h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-3">
          <a href="/DeamonCraft-web/" class="btn-mc btn-mc-daemon text-center text-xs justify-center">🌐 Web</a>
          <a href="https://github.com/AlterMundi/DeamonCraft-web" class="btn-mc bg-void text-cream border-cream/20 text-center text-xs justify-center">??️ Repo</a>
          <a href="https://discord.com/channels/1496673192922710096/1496673192922710099" class="btn-mc bg-[#5865F2] text-cream border-[#5865F2] text-center text-xs justify-center">💬 Discord</a>
          <a href="mailto:nicoechaniz@daemoncraft.ai" class="btn-mc bg-void text-cream border-cream/20 text-center text-xs justify-center">✉️ Contacto</a>
        </div>
      </section>
    </main>
  </div>
</Layout>
